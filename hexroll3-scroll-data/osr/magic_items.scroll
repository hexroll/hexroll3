RandomPotion {
  Item @ [
    *(x3) Potion of Clairaudience
    *(x4) Potion of Clairvoyance
    *(x3) Potion of Control Animal
    *(x3) Potion of Control Dragon
    *(x3) Potion of Control Giant
    *(x3) Potion of Control Human
    *(x3) Potion of Control Plant
    *(x3) Potion of Control Undead
    *(x6) Potion of Delusion
    *(x3) Potion of Diminution
    *(x4) Potion of ESP
    *(x4) Potion of Fire Resistance
    *(x4) Potion of Flying
    *(x4) Potion of Gaseous Form
    *(x4) Potion of Giant Strength
    *(x4) Potion of Growth
    *(x4) Potion of Healing
    *(x5) Potion of Heroism
    *(x4) Potion of Invisibility
    *(x4) Potion of Invulnerability
    *(x4) Potion of Levitation
    *(x4) Potion of Longevity
    *(x2) Potion of Poison
    *(x3) Potion of Polymorph Self
    *(x8) Potion of Speed
    *(x3) Potion of Treasure Finding
    ]
  Description! = "{{Item}}"
}

