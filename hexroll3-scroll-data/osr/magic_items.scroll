SentientSwordExtraLanguageGroupA {
    Language! @ [
      * Elvish
      * Dragon
    ]
}

SentientSwordExtraLanguageGroupB {
    Language! @ [
      * Dwarvish
      * Gnoll
    ]
}

SentientSwordExtraLanguageGroupC {
    Language! @ [
      * Gnomish
      * Goblin
    ]
}

SentientSwordExtraLanguageGroupD {
    Language! @ [
      * Pixie
      * Human
    ]
}

SentientSwordExtraLanguageGroupE {
    Language! @ [
      * Lizardman
      * Hobgoblin
      ]
}

SentientSwordLanguagePlus1 {
   Extra1 @@ [
     * SentientSwordExtraLanguageGroupA
     * SentientSwordExtraLanguageGroupB
     * SentientSwordExtraLanguageGroupC
     * SentientSwordExtraLanguageGroupD
     * SentientSwordExtraLanguageGroupE
   ]
   Text! ~  " and {{Extra1.Language}}"

}

SentientSwordLanguagePlus2 {
   Extra1 @ SentientSwordExtraLanguageGroupA
   Extra2 @ SentientSwordExtraLanguageGroupB
   Text! ~ <%
    , {{Extra1.Language}}, and {{Extra2.Language}}
   %>
}

SentientSwordLanguagePlus3 {
   Extra1 @ SentientSwordExtraLanguageGroupA
   Extra2 @ SentientSwordExtraLanguageGroupB
   Extra3 @ SentientSwordExtraLanguageGroupC
   Text! ~ <%
    , {{Extra1.Language}}, {{Extra2.Language}}, and {{Extra3.Language}}
   %>
}

SentientSwordLanguagePlus4 {
   Extra1 @ SentientSwordExtraLanguageGroupA
   Extra2 @ SentientSwordExtraLanguageGroupB
   Extra3 @ SentientSwordExtraLanguageGroupC
   Extra4 @ SentientSwordExtraLanguageGroupD
   Text! ~ <%, {{Extra1.Language}}, {{Extra2.Language}}, {{Extra3.Language}}, and {{Extra4.Language}}
   %>
}

SentientSwordLanguagePlus5 {
   Extra1 @ SentientSwordExtraLanguageGroupA
   Extra2 @ SentientSwordExtraLanguageGroupB
   Extra3 @ SentientSwordExtraLanguageGroupC
   Extra4 @ SentientSwordExtraLanguageGroupD
   Extra5 @ SentientSwordExtraLanguageGroupE
   Text! ~ <%, {{Extra1.Language}}, {{Extra2.Language}}, {{Extra3.Language}}, {{Extra4.Language}}, and {{Extra5.Language}}
   %>
}

SentientSwordLanguage {
    ^ [
      * SentientSwordLanguagePlus1
      * SentientSwordLanguagePlus2
      * SentientSwordLanguagePlus3
      * SentientSwordLanguagePlus4
      * SentientSwordLanguagePlus5
    ]
}

SentientSwordInt7 {
    Int! = 7
    Reading! = incapable of reading
    Purpose! = false
    Communication! = can only communicate empathically
    Powers! @ [
      * Detect evil
      * Detect magic
      * Detect traps
      * Locate secret door
      * See invisible objects
      * Detect shifting architecture
      * Detect gems
    ]
     Extraordinary! = false
}

SentientSwordInt8 {
    Int! = 8
    Reading! = incapable of reading
    Purpose! = false
    Communication! = can only communicate empathically
      Powers! @ [
      * Detect evil and Detect gems
      * Detect evil and Detect magic
      * Detect slopes and Detect metals
      * Locate secret doors and See invisible objects
      * Locate secret doors and Detect traps
    ]
      Extraordinary! = false

}

SentientSwordInt9 {
    Int! = 9
    Reading! = incapable of reading
    Purpose! = false
    Communication! = can only communicate empathically
      Powers! @ [
      * Detect evil, Detect gems, and Detect metals
      * Detect magic, Detect metals, and Detect slopes
      * Locate secret doors, See invisible objects, and Detect evil
      * Detect magic, Detect gems, and See invisible objects
    ]
      Extraordinary! = false
}

SentientSwordInt10 {
    Int! = 10
    Reading! = incapable of reading
    Language! @ SentientSwordLanguage
    Purpose! = false
    Communication! = can communicate in speech
     Powers! @ [
      * Detect evil, Detect gems, and Detect metals
      * Detect magic, Detect metals, and Detect slopes
      * Locate secret doors, See invisible objects, and Detect evil
      * Detect magic, Detect gems, and See invisible objects
    ]
      Extraordinary! = false
}

SentientSwordInt11 {
    Int! = 11
    Reading! = capable of reading
    Language! @ SentientSwordLanguage
    Purpose! = false
    Communication! = can communicate in speech
    Powers! @ [
      * Detect evil, Detect gems, and Detect metals
      * Detect magic, Detect metals, and Detect slopes
      * Locate secret doors, See invisible objects, and Detect evil
      * Detect magic, Detect gems, and See invisible objects
    ]
    Extraordinary! = false
}

SentientSwordInt12 {
    Int! = 12
    Reading! = capable of reading
    Language! @ SentientSwordLanguage
    Purpose! @ SentientSwordSpecialPurpose
    Communication! = can communicate in speech
    Powers! @ [
      * Detect evil, Detect gems, and Detect metals
      * Detect magic, Detect metals, and Detect slopes
      * Locate secret doors, see invisible objects, and Detect evil
      * Detect magic, Detect gems, and See invisible objects
    ]
    Extraordinary! @ [
      *(x10) Imbued with <strong>Clairaudience</strong>, allowing it to hear through the ears of another creature.
      *(x10) Imbued with <strong>Clairvoyance</strong>, allowing it to see through the eyes of another creature.
      *(x10) Imbued with <strong>ESP</strong>, allowing it to read the thoughts of another creature.
      *(x5)  Imbued with <strong>Extra damage</strong>, allowing the wielder to increase its strength for 1d10 rounds, quadrupling its damage.
      *(x5)  Imbued with <strong>Healing</strong>, allowing the wielder to heal themselves for 6 hit points once per day.
      *(x10) Imbued with <strong>Illusion</strong>, allowing the wielder to manifest an illusion of their choice.
      *(x5)  Imbued with <strong>Levitation</strong>, allowing the wielder to choose to move up and down through the air for up to 3 turns.
      *(x10) Imbued with <strong>Telekinesis</strong>, allowing the wielder to move objects or creatures within 120' by the power of thought.
      *(x10) Imbued with <strong>Teleportation</strong>, allowing the wielder to use the teleport spell at will.
      *(x10) Imbued with <strong>X-ray vision</strong>, allowing the wielder to see through solid objects.
    ]
}


SentientSwordInt {
   ^ [
     * SentientSwordInt7
     * SentientSwordInt8
     * SentientSwordInt9
     * SentientSwordInt10
     * SentientSwordInt11
     * SentientSwordInt12
   ]
}

SentientSwordSpecialPurpose {
  ^ [
       *(x3) SentientSwordHasSpecialPurpose
       *(x7) SentientSwordNoSpecialPurpose
  ]
}

SentientSwordHasSpecialPurpose {
    Ego! = 12
    Text! ~ "The sword has a special purpose, Requiring the wielder to <strong>slay "
    Roll! @ [
        * lawful creatures</strong>.
        * chaotic creatures</strong>.
        * arcane spell casters</strong>.
        * divine spell casters</strong>.
        * warriors</strong>.
        * monsters</strong>.
    ]
}

SentientSwordNoSpecialPurpose {
    Ego! @ 1d12
    Roll! @ [
    *
    ]
    Text! = ""
}

SentientSword {

   Ego! @ 1d12

   Alignment! @ [
        *(x13) Lawful
        *(x5) Neutral
        *(x2) Chaotic
    ]

    Prefix! @ [
        * Ale
        * Mon
        * Elli
        * Dia
        * Mur
        * Bes
        * Ara
        * Sen
        * Es
        * Kor
        * Rot
      ]

    Suffix! @ [
        * gar
        * tam
        * sin
        * mar
        * mor
        * fin
        * quit
        * den
        * for
      ]

    Intelligence @ SentientSwordInt
    Language @ SentientSwordLanguage

    Description! ~ <%
      a Sentient Sword named <strong>{{Prefix}}{{Suffix}}</strong>.
      <hr/>
      <strong>Alignment:</strong> {{Alignment}}
      <strong>INT:</strong> {{Intelligence.Int}}
      <strong>Ego:</strong> {% if Intelligence.Purpose %}{{Intelligence.Purpose.Ego}}{%else%}{{Ego}}{%endif%}
      {{Intelligence.Reading}} and
      {{Intelligence.Communication}}
      <strong>Languages:</strong> {{Alignment}}{{Language.Text}}
      <strong>Powers:</strong> {{Intelligence.Powers}}
      {% if Intelligence.Extraordinary %} {{Intelligence.Extraordinary}} {% endif %}
      {% if Intelligence.Purpose %}
      {{Intelligence.Purpose.Text}}{{Intelligence.Purpose.Roll}}
      {% endif %}
      <hr/>
    %>
}
