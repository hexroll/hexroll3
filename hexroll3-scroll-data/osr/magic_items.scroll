LegendaryItem {
  HexLink = :Hex.uuid
  HexRegion = :Hex.Region
  Item @ [
    *(x1) Cloak of invisibility
    *(x1) Holy Avenger
    *(x1) Armour +3, Shield +3
    *(x1) Armour +3
    *(x1) Shield +3
    *(x1) Girdle of Giant Strength
    *(x1) Deck of Many Things
    *(x1) Efreeti Bottle
    *(x1) War Hammer +3, Dwarven Thrower
    *(x1) Ring of Invisibility
    *(x1) Horn of Blasting
  ]
  Description! = "{{Item}}"
  Link! ~ <%
    {% if exists("HexRegion") %}
    <li>
   {{begin_spoiler()}}
    The <strong>{{Item}}</strong> is somewhere
    </strong> in <a href="{{sandbox()}}/hex/{{HexLink}}"><strong>{{HexRegion}} </a> </strong>
   {{end_spoiler()}}
    </li>
    {% endif %}
  %>
}

RandomScroll {
  ^ [
    *(x3) SpellScroll1stLevel
    *(x4) SpellScroll2ndLevel
    *(x5) SpellScroll3rdLevel
    *(x3) SpellScroll4thLevel
    *(x2) SpellScroll5thLevel
    *(x1) SpellScroll6thLevel
  ]
}

SpellScroll1stLevel {
  Spell @ [
    * Charm Person <small>(Magic-User)</small>
    * Cure/Inflict Light Wounds <small>(Cleric)</small>
    * Detect Evil <small>(Cleric)</small>
    * Detect Magic <small>(Cleric, Magic-User)</small>
    * Floating Disc <small>(Magic-User)</small>
    * Hold Portal <small>(Magic-User)</small>
    * Light/Darkness <small>(Cleric, Magic-User)</small>
    * Magic Missile <small>(Magic-User)</small>
    * Protection from Evil <small>(Cleric, Magic-User)</small>
    * Purify Food and Water <small>(Cleric)</small>
    * Read Languages <small>(Magic-User)</small>
    * Read Magic <small>(Magic-User)</small>
    * Remove/Cause Fear <small>(Cleric)</small>
    * Resist Cold <small>(Cleric)</small>
    * Shield <small>(Magic-User)</small>
    * Sleep <small>(Magic-User)</small>
    * Ventriloquism <small>(Magic-User)</small>
  ]
  Description! ~ "Scroll<sup>1st</sup> of {{Spell}}"
}

SpellScroll2ndLevel {
  Spell @ [
    * Bless/Blight <small>(Cleric)</small>
    * Continual Light/Darkness <small>(Magic-User)</small>
    * Detect Evil <small>(Magic-User)</small>
    * Detect Invisible <small>(Magic-User)</small>
    * ESP <small>(Magic-User)</small>
    * Find Traps <small>(Cleric)</small>
    * Hold Person <small>(Cleric)</small>
    * Invisibility <small>(Magic-User)</small>
    * Know Alignment <small>(Cleric)</small>
    * Knock <small>(Magic-User)</small>
    * Levitate <small>(Magic-User)</small>
    * Locate Object <small>(Magic-User)</small>
    * Mirror Image <small>(Magic-User)</small>
    * Phantasmal Force <small>(Magic-User)</small>
    * Resist Fire <small>(Cleric)</small>
    * Silence 15' Radius <small>(Cleric)</small>
    * Snake Charm <small>(Cleric)</small>
    * Speak with Animals <small>(Cleric)</small>
    * Web <small>(Magic-User)</small>
    * Wizard Lock <small>(Magic-User)</small>
  ]
  Description! ~ "Scroll<sup>2nd</sup> of {{Spell}}"
}

